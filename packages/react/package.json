{
  "name": "@protohiro/effects",
  "version": "0.3.1",
  "description": "React hooks for hard CSS effects like gradient borders, spotlight reveal, and glass highlights without wrappers.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/protohiro-com/effects.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/protohiro-com/effects#readme",
  "bugs": {
    "url": "https://github.com/protohiro-com/effects/issues"
  },
  "keywords": [
    "protoeffects",
    "protohiro",
    "react",
    "hooks",
    "css",
    "effects",
    "react-hooks",
    "css-effects",
    "ui-effects",
    "hard-css-effects",
    "zero-wrapper",
    "no-wrapper",
    "single-element",
    "pseudo-element",
    "design-system-effects",
    "react-css-effects",
    "gradient-border",
    "react-gradient-border",
    "glass-highlight",
    "react-glass-effect",
    "glow",
    "spotlight",
    "spotlight-reveal",
    "react-spotlight",
    "noise-overlay",
    "design-system"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "dependencies": {
    "@protohiro/effects-core": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
